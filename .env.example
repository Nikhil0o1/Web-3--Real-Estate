DATABASE_URL=postgresql://postgres:your_password@your-db-host:5432/real_estate_web3
ALCHEMY_API_KEY=your-alchemy-api-key
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/your-alchemy-api-key
WEB3_PROVIDER_URI=https://eth-sepolia.g.alchemy.com/v2/your-alchemy-api-key
CHAIN_ID=11155111
DEPLOY_ENV=production
DEPLOYER_PRIVATE_KEY=0xYOUR_SEPOLIA_FUNDED_PRIVATE_KEY
FRONTEND_URL=https://your-frontend-domain.example
BACKEND_URL=https://your-backend-domain.example
API_BASE_URL=https://your-backend-domain.example
CORS_ORIGINS=https://your-frontend-domain.example,https://your-backend-domain.example
CONTRACT_ADDRESSES_PATH=backend/config/contract-addresses.json
ARTIFACTS_DIR=artifacts/contracts
TOKEN_DECIMALS=18
RENT_TOKEN_DECIMALS=6

# Indexer configuration
# Deploy block of RentDistribution on Sepolia — avoids scanning from genesis.
INDEXER_START_BLOCK=0
# Set to "false" in production when running the worker as a separate process.
# Keep "true" in development for single-process convenience.
RUN_INDEXER_IN_WEB=true
# Stable 64-bit integer used for pg_try_advisory_lock. Don't change unless you
# have a reason; must be identical across all indexer processes.
INDEXER_ADVISORY_LOCK_KEY=928374651234

# ───────────────────────────────────────────────────────────
# Web3 Wallet Authentication
# ───────────────────────────────────────────────────────────
# Long random secret used to sign session JWTs. REQUIRED in production.
# Generate with:  python -c "import secrets; print(secrets.token_hex(48))"
AUTH_JWT_SECRET=replace-with-a-long-random-secret
# JWT algorithm + issuer (do not change unless you know what you're doing)
AUTH_JWT_ALGORITHM=HS256
AUTH_JWT_ISSUER=estatechain
# Session lifetime in hours
AUTH_SESSION_TTL_HOURS=24
# How long a /auth/nonce challenge is valid for, in seconds
AUTH_NONCE_TTL_SECONDS=300

# ───────────────────────────────────────────────────────────
# AI orchestration foundation (Phase 1 — optional; no keys required to boot)
# ───────────────────────────────────────────────────────────
AI_ORCHESTRATION_ENABLED=true
# openai | anthropic | local (provider wiring expands in later phases)
AI_PROVIDER=openai
AI_DEFAULT_MODEL=gpt-4o-mini
AI_REQUEST_TIMEOUT_S=120
AI_MAX_TOOL_ROUNDS=8
AI_STREAM_TEST_DELAY_S=0.05
# AI_LOG_GRAPH_STRUCTURE=false
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# AI_LOCAL_MODEL_BASE_URL=
